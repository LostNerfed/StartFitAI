<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="synergyfit_database"/>
        <exclude domain="database" path="synergyfit_database-shm"/>
        <exclude domain="database" path="synergyfit_database-wal"/>
        <exclude domain="file" path="backup_month_.+\.enc"/>
        <exclude domain="sharedpref" path="."/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="synergyfit_database"/>
        <exclude domain="database" path="synergyfit_database-shm"/>
        <exclude domain="database" path="synergyfit_database-wal"/>
        <exclude domain="file" path="backup_month_.+\.enc"/>
        <exclude domain="sharedpref" path="."/>
    </device-transfer>
</data-extraction-rules>
